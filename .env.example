# Required: Claude API key for the brain
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enable self-editing code (dangerous, off by default)
JARVIS_SELF_EDIT_ENABLED=false

# Optional: model overrides (defaults to claude-opus-4-7)
JARVIS_MODEL=claude-opus-4-7

# Optional: HubSpot -> Outreach workflow stubs
HUBSPOT_API_KEY=
OUTREACH_API_KEY=
BLUESEND_API_KEY=
THANKS_IO_API_KEY=
